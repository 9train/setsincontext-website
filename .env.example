# Remote mode stays disabled until this website is pointed at a deployed runtime.
# That runtime must serve:
# - /host.html
# - /viewer.html
# - GET /api/sessions/resolve?key=<room>[&access=<token>]
# - GET /api/sessions/:room/invite?hostAccess=<token>
# - websocket joins for host/viewer sessions

# Required: deployed runtime HTTP origin
VITE_REMOTE_RUNTIME_ORIGIN=

# Optional when the websocket host matches the HTTP origin.
# Required when the websocket host lives elsewhere.
VITE_REMOTE_RUNTIME_WS_URL=
